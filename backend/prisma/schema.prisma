generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int              @id @default(autoincrement())
  name           String
  email          String           @unique
  password       String           @db.VarChar(255)
  createdAt      DateTime         @default(now())
  token          String?          @db.VarChar(255)
  SavedTimetable SavedTimetable[]
  connectors     Connector[]
}

model SavedTimetable {
  id        String   @id @default(uuid())
  userId    Int
  timetable Json
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Connector {
  id          String       @id @default(uuid())
  name        String       @unique
  apiUrl      String
  userId      Int
  user        User         @relation(fields: [userId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  line        Line?
  stop        Stop?
  direction   Direction?
  nextPassage NextPassage?
}

model Line {
  id             String    @id @default(uuid())
  name           String
  apiUrl         String
  transformation Json
  connectorId    String    @unique
  connector      Connector @relation(fields: [connectorId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Stop {
  id             String    @id @default(uuid())
  name           String
  apiUrl         String
  transformation Json
  connectorId    String    @unique
  connector      Connector @relation(fields: [connectorId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Direction {
  id             String    @id @default(uuid())
  name           String
  apiUrl         String
  transformation Json
  connectorId    String    @unique
  connector      Connector @relation(fields: [connectorId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model NextPassage {
  id             String    @id @default(uuid())
  name           String
  apiUrl         String
  transformation Json
  connectorId    String    @unique
  connector      Connector @relation(fields: [connectorId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
